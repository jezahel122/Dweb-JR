        <!--Conjunto de etiquetas, formularios la etiqueta <form> me permite agrupar distintas etiquetas
        como etiquetas lable, imput, selection, radio button, button, entre otras-->
        <div>
            <h2>Formulario de Datos</h2>
            <form action="">
                <div>
                <label for="nombre">Ingrese el nombre:</label>
                <input type="text" id="nombre" name="nombre" required> <!--required, para avisar que debe llenar los datos-->
                </div>

                <div>
                    <label for="edad">Ingrese la edad del estudiante</label>
                    <input type="number" id="edad" name="edad">
                </div>

                <div>
                    <input type="submit" value="Enviar"> <!--submit, hacer solicitud-->
                </div>
            </form>
        </div>
    
    </div>
